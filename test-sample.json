{
  "schema_version": "0.2.0",
  "source": "design-agent-studio",
  "flow_name": "Onboarding MVP",
  "flow_structure": "linear",
  "viewport": "mobile",
  "export_scope": "full",

  "design_system": {
    "name": "ad-hoc",
    "colors": {
      "primary": "#3B82F6",
      "secondary": "#F97316",
      "neutrals": ["#F9FAFB", "#E5E7EB", "#9CA3AF", "#6B7280", "#374151", "#111827"],
      "semantic": {
        "success": "#22C55E",
        "warning": "#F59E0B",
        "error": "#EF4444",
        "info": "#3B82F6"
      }
